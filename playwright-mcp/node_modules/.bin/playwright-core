else
  export NODE_PATH="/mnt/c/Workspace/petrobras-quest/playwright-mcp/node_modules/playwright-core/node_modules:/mnt/c/Workspace/petrobras-quest/playwright-mcp/node_modules:/mnt/c/Workspace/petrobras-quest/node_modules:/mnt/c/Workspace/node_modules:/mnt/c/node_modules:/mnt/c/Workspace/petrobras-quest/playwright-mcp/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../playwright-core/cli.js" "$@"
else
  exec node  "$basedir/../playwright-core/cli.js" "$@"
fi
