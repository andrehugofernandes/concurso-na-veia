              corIndicador="bg-rose-500"
              defaultOpen={false}
              slides={[
                {
                  titulo: "(Aᶜ ∩ Bᶜ)ᶜ = ?",
                  icone: "🧮",
                  conteudo:(
                    <div className="space-y-4">
                      <p className="text-sm text-muted-foreground leading-relaxed">
                        Expressões com duas aplicações de De Morgan são cobradas
