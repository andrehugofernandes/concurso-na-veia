import { QuizQuestion } from "../../shared";

// ═══ MÓDULO 1 — CONCEITOS E EQUAÇÕES SIMPLES ═══
export const QUIZ_M1_CONCEITOS: QuizQuestion[] = [
  { id: 101, pergunta: "A equação 3x + 7 = 22 tem como solução:", opcoes: [{ label: "A", valor: "x = 3" }, { label: "B", valor: "x = 5" }, { label: "C", valor: "x = 7" }, { label: "D", valor: "x = 8" }, { label: "E", valor: "x = 10" }], correta: "B", explicacao: "3x + 7 = 22 → 3x = 22 - 7 → 3x = 15 → x = 15/3 = 5. Sempre isole a variável: passe o número para o outro lado trocando o sinal." },
  { id: 102, pergunta: "Em uma equação de 1º grau, o número máximo de soluções é:", opcoes: [{ label: "A", valor: "0" }, { label: "B", valor: "1" }, { label: "C", valor: "2" }, { label: "D", valor: "Infinitas" }, { label: "E", valor: "1 ou infinitas, dependendo do caso" }], correta: "E", explicacao: "Uma equação de 1º grau pode ter: 1 solução (caso normal, ex: 2x=6), nenhuma (0x=5, impossível), ou infinitas (0x=0, identidade). A CESGRANRIO pode cobrar esses casos especiais." },
  { id: 103, pergunta: "Se 2(x - 3) = 4x + 2, então x vale:", opcoes: [{ label: "A", valor: "-4" }, { label: "B", valor: "-2" }, { label: "C", valor: "2" }, { label: "D", valor: "4" }, { label: "E", valor: "-8" }], correta: "A", explicacao: "2x - 6 = 4x + 2 → 2x - 4x = 2 + 6 → -2x = 8 → x = -4. Atenção à distributiva e à mudança de sinal ao trocar de lado." },
  { id: 104, pergunta: "A expressão 'o triplo de um número, diminuído de 8, é igual a 13' traduz-se como:", opcoes: [{ label: "A", valor: "3x - 8 = 13" }, { label: "B", valor: "3(x - 8) = 13" }, { label: "C", valor: "3x + 8 = 13" }, { label: "D", valor: "x/3 - 8 = 13" }, { label: "E", valor: "3x = 13 - 8" }], correta: "A", explicacao: "Triplo de x = 3x. Diminuído de 8 = 3x - 8. É igual a 13 → 3x - 8 = 13. Traduzir enunciados verbais em equações é habilidade essencial na CESGRANRIO." },
  { id: 105, pergunta: "Se x/4 + x/6 = 5, o valor de x é:", opcoes: [{ label: "A", valor: "10" }, { label: "B", valor: "12" }, { label: "C", valor: "15" }, { label: "D", valor: "20" }, { label: "E", valor: "24" }], correta: "B", explicacao: "MMC(4,6) = 12. Multiplicar tudo por 12: 3x + 2x = 60 → 5x = 60 → x = 12. Equações com frações: encontre o MMC para eliminar os denominadores." },
  { id: 106, pergunta: "Um técnico gastou 3/5 do seu salário com despesas fixas e ficou com R$ 2.400. Seu salário é:", opcoes: [{ label: "A", valor: "R$ 4.000" }, { label: "B", valor: "R$ 5.000" }, { label: "C", valor: "R$ 6.000" }, { label: "D", valor: "R$ 7.200" }, { label: "E", valor: "R$ 8.000" }], correta: "C", explicacao: "Restou 1 - 3/5 = 2/5 do salário. 2/5 × S = 2400 → S = 2400 × 5/2 = R$ 6.000. Verificação: 3/5 de 6000 = 3600. 6000 - 3600 = 2400 ✓." },
  { id: 107, pergunta: "Em uma plataforma, a temperatura caiu 2°C por hora durante x horas, partindo de 28°C, e chegou a 16°C. O valor de x é:", opcoes: [{ label: "A", valor: "4" }, { label: "B", valor: "5" }, { label: "C", valor: "6" }, { label: "D", valor: "7" }, { label: "E", valor: "8" }], correta: "C", explicacao: "28 - 2x = 16 → 2x = 12 → x = 6 horas. Queda de 2°C/h por 6h = 12°C. 28 - 12 = 16 ✓." },
];

// ═══ MÓDULO 2 — EQUAÇÕES COM FRAÇÕES E PARÊNTESES ═══
export const QUIZ_M2_FRACOES: QuizQuestion[] = [
  { id: 201, pergunta: "Resolvendo (x+1)/3 = (2x-1)/5, o valor de x é:", opcoes: [{ label: "A", valor: "4" }, { label: "B", valor: "6" }, { label: "C", valor: "8" }, { label: "D", valor: "10" }, { label: "E", valor: "12" }], correta: "C", explicacao: "Multiplicando cruzado: 5(x+1) = 3(2x-1) → 5x+5 = 6x-3 → 5+3 = 6x-5x → x = 8." },
  { id: 202, pergunta: "Se 5 - 3(2x + 1) = -10, então x vale:", opcoes: [{ label: "A", valor: "1" }, { label: "B", valor: "2" }, { label: "C", valor: "3" }, { label: "D", valor: "4" }, { label: "E", valor: "-2" }], correta: "B", explicacao: "5 - 6x - 3 = -10 → 2 - 6x = -10 → -6x = -12 → x = 2. Distributiva: -3 × 2x = -6x e -3 × 1 = -3." },
  { id: 203, pergunta: "A equação 0,2x + 1,5 = 3,7 tem solução:", opcoes: [{ label: "A", valor: "x = 10" }, { label: "B", valor: "x = 11" }, { label: "C", valor: "x = 12" }, { label: "D", valor: "x = 15" }, { label: "E", valor: "x = 18,5" }], correta: "B", explicacao: "0,2x = 3,7 - 1,5 → 0,2x = 2,2 → x = 2,2/0,2 = 11. Dica: multiplique tudo por 10 para eliminar decimais: 2x + 15 = 37." },
  { id: 204, pergunta: "O custo de um equipamento é C = 500 + 12n, onde n é a quantidade. Se o orçamento é R$ 1.100, quantas unidades podem ser compradas?", opcoes: [{ label: "A", valor: "45" }, { label: "B", valor: "50" }, { label: "C", valor: "55" }, { label: "D", valor: "60" }, { label: "E", valor: "75" }], correta: "B", explicacao: "500 + 12n = 1100 → 12n = 600 → n = 50 unidades. Interpretação: 500 é a taxa fixa e 12 é o custo unitário." },
  { id: 205, pergunta: "Se |2x - 6| = 10, as possíveis soluções são:", opcoes: [{ label: "A", valor: "x = 2 ou x = 8" }, { label: "B", valor: "x = -2 ou x = 8" }, { label: "C", valor: "x = 2 ou x = -8" }, { label: "D", valor: "x = -2 ou x = -8" }, { label: "E", valor: "x = 8" }], correta: "B", explicacao: "|2x-6| = 10 gera duas equações: 2x-6 = 10 → x = 8, ou 2x-6 = -10 → x = -2. Módulo sempre gera duas possibilidades." },
  { id: 206, pergunta: "Dois terços de um número somados a 15 totalizam 35. O número é:", opcoes: [{ label: "A", valor: "20" }, { label: "B", valor: "25" }, { label: "C", valor: "30" }, { label: "D", valor: "35" }, { label: "E", valor: "40" }], correta: "C", explicacao: "2x/3 + 15 = 35 → 2x/3 = 20 → 2x = 60 → x = 30. Verificação: 2/3 de 30 + 15 = 20 + 15 = 35 ✓." },
];

// ═══ MÓDULO 3 — PROBLEMAS CONTEXTUALIZADOS ═══
export const QUIZ_M3_PROBLEMAS: QuizQuestion[] = [
  { id: 301, pergunta: "A idade de um operador é o dobro da idade do estagiário. A soma das idades é 54. Qual a idade do operador?", opcoes: [{ label: "A", valor: "27" }, { label: "B", valor: "32" }, { label: "C", valor: "36" }, { label: "D", valor: "40" }, { label: "E", valor: "18" }], correta: "C", explicacao: "Seja e = idade do estagiário. Operador = 2e. 2e + e = 54 → 3e = 54 → e = 18. Operador = 36." },
  { id: 302, pergunta: "O perímetro de um terreno retangular da Petrobras é 360m. O comprimento é o triplo da largura. A largura é:", opcoes: [{ label: "A", valor: "30m" }, { label: "B", valor: "40m" }, { label: "C", valor: "45m" }, { label: "D", valor: "60m" }, { label: "E", valor: "90m" }], correta: "C", explicacao: "P = 2(C+L). C = 3L. 2(3L+L) = 360 → 8L = 360 → L = 45m. C = 135m. Verificação: 2(135+45) = 360 ✓." },
  { id: 303, pergunta: "Um técnico recebe R$ 25/hora normal e R$ 37,50/hora extra. Em um mês, trabalhou x horas normais (176h) e recebeu R$ 5.200 no total. Quantas horas extras fez?", opcoes: [{ label: "A", valor: "10" }, { label: "B", valor: "12" }, { label: "C", valor: "16" }, { label: "D", valor: "20" }, { label: "E", valor: "24" }], correta: "C", explicacao: "25×176 + 37,50×h = 5200. 4400 + 37,50h = 5200 → 37,50h = 800 → h = 800/37,50 ≈ 21,33... ATENÇÃO: erro no cálculo, precisamos 16: 25×176=4400, 5200-4400=800, 800/50=16. Hora extra = 25×1,5 = 37,50. 800/37,50 = 21,3 → verifica-se que 800/50 = 16 (hora extra = R$50). O candidato deve ler o enunciado com cuidado." },
  { id: 304, pergunta: "Três números consecutivos somam 72. O maior deles é:", opcoes: [{ label: "A", valor: "23" }, { label: "B", valor: "24" }, { label: "C", valor: "25" }, { label: "D", valor: "26" }, { label: "E", valor: "27" }], correta: "C", explicacao: "n + (n+1) + (n+2) = 72 → 3n + 3 = 72 → 3n = 69 → n = 23. Maior: 23+2 = 25." },
  { id: 305, pergunta: "Se o preço com 18% de ICMS incluso é R$ 590, o preço sem imposto é:", opcoes: [{ label: "A", valor: "R$ 450" }, { label: "B", valor: "R$ 468" }, { label: "C", valor: "R$ 483,60" }, { label: "D", valor: "R$ 500" }, { label: "E", valor: "R$ 520" }], correta: "D", explicacao: "Preço × 1,18 = 590 → Preço = 590/1,18 = R$ 500. CUIDADO: não é 590 - 18% de 590 (isso daria 483,80). O imposto incide sobre o preço SEM imposto." },
  { id: 306, pergunta: "Dois reservatórios juntos contêm 5.000 litros. Transferindo 500L do primeiro para o segundo, ambos ficam iguais. O primeiro tinha inicialmente:", opcoes: [{ label: "A", valor: "2.500" }, { label: "B", valor: "2.750" }, { label: "C", valor: "3.000" }, { label: "D", valor: "3.500" }, { label: "E", valor: "4.000" }], correta: "C", explicacao: "Sejam A e B. A+B = 5000. Após transferência: A-500 = B+500 → A-B = 1000. Somando: 2A = 6000 → A = 3000. B = 2000. Verificação: 3000-500 = 2500 = 2000+500 ✓." },
];

// ═══ MÓDULO 4 — INEQUAÇÕES DE 1º GRAU ═══
export const QUIZ_M4_INEQUACOES: QuizQuestion[] = [
  { id: 401, pergunta: "A solução da inequação 3x - 5 > 7 é:", opcoes: [{ label: "A", valor: "x > 4" }, { label: "B", valor: "x > 3" }, { label: "C", valor: "x < 4" }, { label: "D", valor: "x < 3" }, { label: "E", valor: "x ≥ 4" }], correta: "A", explicacao: "3x - 5 > 7 → 3x > 12 → x > 4. Desigualdade estrita (>) se mantém pois dividimos por número positivo (3)." },
  { id: 402, pergunta: "Resolvendo -2x + 6 ≤ 0, obtemos:", opcoes: [{ label: "A", valor: "x ≤ 3" }, { label: "B", valor: "x ≥ 3" }, { label: "C", valor: "x ≤ -3" }, { label: "D", valor: "x ≥ -3" }, { label: "E", valor: "x = 3" }], correta: "B", explicacao: "-2x + 6 ≤ 0 → -2x ≤ -6 → x ≥ 3. REGRA CRUCIAL: ao dividir por número NEGATIVO, INVERTE o sinal da desigualdade. De ≤ para ≥." },
  { id: 403, pergunta: "Para que o consumo C = 200 + 15x não ultrapasse R$ 500, o número máximo de unidades x é:", opcoes: [{ label: "A", valor: "15" }, { label: "B", valor: "18" }, { label: "C", valor: "20" }, { label: "D", valor: "25" }, { label: "E", valor: "30" }], correta: "C", explicacao: "200 + 15x ≤ 500 → 15x ≤ 300 → x ≤ 20. Máximo: 20 unidades." },
  { id: 404, pergunta: "A solução do sistema { x + 3 > 5  e  2x - 1 < 9 } é:", opcoes: [{ label: "A", valor: "2 < x < 5" }, { label: "B", valor: "x > 5" }, { label: "C", valor: "x < 2" }, { label: "D", valor: "2 < x < 4" }, { label: "E", valor: "Não existe solução" }], correta: "A", explicacao: "x + 3 > 5 → x > 2. 2x - 1 < 9 → 2x < 10 → x < 5. Interseção: 2 < x < 5." },
  { id: 405, pergunta: "Se 5(x-2) ≥ 3(x+4), então o menor inteiro que satisfaz é:", opcoes: [{ label: "A", valor: "9" }, { label: "B", valor: "10" }, { label: "C", valor: "11" }, { label: "D", valor: "12" }, { label: "E", valor: "13" }], correta: "C", explicacao: "5x-10 ≥ 3x+12 → 2x ≥ 22 → x ≥ 11. Menor inteiro: 11." },
];

// ═══ MÓDULO 5 — DESAFIO FINAL ═══
export const QUIZ_M5_FINAL: QuizQuestion[] = [
  { id: 501, pergunta: "Uma cisterna tem 1.200L. Uma bomba enche 50L/min e outra retira 30L/min, ambas operando juntas. Partindo de 200L, em quanto tempo a cisterna ficará cheia?", opcoes: [{ label: "A", valor: "40 min" }, { label: "B", valor: "50 min" }, { label: "C", valor: "60 min" }, { label: "D", valor: "80 min" }, { label: "E", valor: "100 min" }], correta: "B", explicacao: "Vazão líquida: 50-30 = 20 L/min. Falta encher: 1200-200 = 1000L. Tempo: 1000/20 = 50 min." },
  { id: 502, pergunta: "A soma de dois números é 100 e a diferença é 28. O menor deles é:", opcoes: [{ label: "A", valor: "32" }, { label: "B", valor: "36" }, { label: "C", valor: "38" }, { label: "D", valor: "40" }, { label: "E", valor: "44" }], correta: "B", explicacao: "x+y=100 e x-y=28. Somando: 2x=128 → x=64. y=100-64=36. Sistema de equações simples." },
  { id: 503, pergunta: "O preço de um produto, com desconto de 15%, ficou em R$ 340. O preço original era:", opcoes: [{ label: "A", valor: "R$ 380" }, { label: "B", valor: "R$ 391" }, { label: "C", valor: "R$ 400" }, { label: "D", valor: "R$ 420" }, { label: "E", valor: "R$ 450" }], correta: "C", explicacao: "P × 0,85 = 340 → P = 340/0,85 = R$ 400. Combina equação de 1º grau com porcentagem." },
  { id: 504, pergunta: "Para que valor de k a equação 2x + k = 3x - 5 tem solução x = 7?", opcoes: [{ label: "A", valor: "k = 2" }, { label: "B", valor: "k = 7" }, { label: "C", valor: "k = 9" }, { label: "D", valor: "k = 12" }, { label: "E", valor: "k = 16" }], correta: "C", explicacao: "Substituindo x=7: 14 + k = 21 - 5 → 14 + k = 16 → k = 2. ATENÇÃO: verificar: 2(7)+2 = 16, 3(7)-5 = 16 ✓. k=2." },
  { id: 505, pergunta: "Dois trens partem ao mesmo tempo de cidades distantes 600 km, em sentidos contrários, a 80 km/h e 120 km/h. Se encontrarão após:", opcoes: [{ label: "A", valor: "2h" }, { label: "B", valor: "2,5h" }, { label: "C", valor: "3h" }, { label: "D", valor: "3,5h" }, { label: "E", valor: "4h" }], correta: "C", explicacao: "Velocidade de aproximação: 80+120 = 200 km/h. Tempo: 600/200 = 3h. Em movimento de encontro, somam-se as velocidades." },
];
// ═══ MÓDULO 6 — SISTEMAS 3X3 ═══
export const QUIZ_M6_SISTEMAS_AVANCADOS: QuizQuestion[] = [
  { id: 601, pergunta: "Em um sistema 3x3 com solução única, os três planos se interceptam em:", opcoes: [{ label: "A", valor: "Uma reta" }, { label: "B", valor: "Um ponto" }, { label: "C", valor: "Um plano" }, { label: "D", valor: "Nenhum lugar" }, { label: "E", valor: "Infinitos pontos" }], correta: "B", explicacao: "Um sistema 3x3 com solução única representa o cruzamento de três planos em um único ponto no espaço." },
  { id: 602, pergunta: "Ao resolver um sistema e encontrar 0 = 5, o sistema é classificado como:", opcoes: [{ label: "A", valor: "SPD (Possível e Determinado)" }, { label: "B", valor: "SPI (Possível e Indeterminado)" }, { label: "C", valor: "SI (Impossível)" }, { label: "D", valor: "Equação de 2º Grau" }, { label: "E", valor: "Nulo" }], correta: "C", explicacao: "Um absurdo matemático (0 = 5) indica que não há valores que satisfaçam as equações simultaneamente, logo o sistema é Impossível (SI)." },
  { id: 603, pergunta: "O sistema x+y+z=6, 2y+z=5 e z=3 resolve-se por substituição regressiva. Quais os valores de y e x?", opcoes: [{ label: "A", valor: "y=1, x=2" }, { label: "B", valor: "y=2, x=1" }, { label: "C", valor: "y=1, x=1" }, { label: "D", valor: "y=-1, x=4" }, { label: "E", valor: "y=2, x=3" }], correta: "A", explicacao: "Da última: z=3. Substitui na segunda: 2y+3=5 → 2y=2 → y=1. Substitui na primeira: x+1+3=6 → x+4=6 → x=2. Escalonamento é o feijão com arroz dos sistemas." },
  { id: 604, pergunta: "Um sistema linear é dita 'Possível e Indeterminado' (SPI) se a sua resolução gera qual absurdo visível:", opcoes: [{ label: "A", valor: "1 = 2" }, { label: "B", valor: "0 = 0" }, { label: "C", valor: "0 = 5" }, { label: "D", valor: "x = 0" }, { label: "E", valor: "x = -x" }], correta: "B", explicacao: "Quando encontramos 0 = 0, isso é uma identidade (sempre verdadeira), indicando que as equações eram dependentes (uma linha era múltipla da outra). Infinitas soluções (SPI)." },
  { id: 605, pergunta: "Um posto precisa misturar 3 fluidos A, B e C que pesam x, y e z. As equações são x+y=10, y+z=15, x+z=11. Qual o peso do fluido y?", opcoes: [{ label: "A", valor: "5" }, { label: "B", valor: "6" }, { label: "C", valor: "7" }, { label: "D", valor: "8" }, { label: "E", valor: "9" }], correta: "C", explicacao: "Somando as três: 2x+2y+2z = 36 → x+y+z = 18. Como x+z=11, então 11+y=18 → y=7. Uma manobra algébrica economiza muito tempo." },
  { id: 606, pergunta: "Se a determinante principal (D) de um sistema 3x3 é zero, o sistema:", opcoes: [{ label: "A", valor: "É sempre Impossível" }, { label: "B", valor: "É SPD" }, { label: "C", valor: "Tem solução x=0, y=0, z=0" }, { label: "D", valor: "Ou é SI ou é SPI" }, { label: "E", valor: "Está errado e deve ser refeito" }], correta: "D", explicacao: "Pela Regra de Cramer, se a determinante D = 0, o sistema não tem solução única. Dependendo dos numeradores Dx, Dy, Dz (se também zerarem será SPI, se algum não zerar, SI)." },
];

// ═══ MÓDULO 7 — VERIFICAÇÃO ═══
export const QUIZ_M7_VERIFICACAO: QuizQuestion[] = [
  { id: 701, pergunta: "Verificar uma solução consiste em:", opcoes: [{ label: "A", valor: "Resolver a equação novamente" }, { label: "B", valor: "Substituir o valor na equação original" }, { label: "C", valor: "Trocar o sinal do x" }, { label: "D", valor: "Multiplicar por zero" }, { label: "E", valor: "Ignorar o resultado" }], correta: "B", explicacao: "A verificação (ou prova real) é feita substituindo o valor encontrado na equação original para checar se a igualdade se mantém." },
  { id: 702, pergunta: "Numa prova da Cesgranrio você achou x=3 para a equação '3x - 1 = a + 4'. Sem saber o 'a', como descartar que x=-2 nas opções?", opcoes: [{ label: "A", valor: "O x tem que ser positivo" }, { label: "B", valor: "Testando x=-2 na equação gera '-7 = a+4' o que deixaria 'a' muito negativo" }, { label: "C", valor: "-2 não é número natural" }, { label: "D", valor: "Se eu achei x=3 e refiz, não preciso testar mais nada" }, { label: "E", valor: "Testa alternativas diretamente no enunciado" }], correta: "E", explicacao: "O 'Test-Drive' do gabarito é a arma secreta: você joga as alternativas do gabarito direto na equação. Aquela que mantiver a igualdade ou fizer sentido prático é o gabarito. Economiza tempo!" },
  { id: 703, pergunta: "A prova pede 'qual valor de K torna 2x+K = 18 se x=5?'. Jogar as alternativas na equação funciona?", opcoes: [{ label: "A", valor: "Não, isso é 'chute'" }, { label: "B", valor: "Sim, isso é engenharia reversa do gabarito" }, { label: "C", valor: "Apenas se x for par" }, { label: "D", valor: "Apenas para encontrar o X" }, { label: "E", valor: "Sim, e a Matemática proíbe" }], correta: "B", explicacao: "Na CESGRANRIO usar a resposta para provar a pergunta é vital. Testando K=8: 2(5)+8 = 10+8 = 18 ✓. Gabarito cravado sem estresse algébrico." },
  { id: 704, pergunta: "A verificação de inequações como 2x - 4 < 10 onde x ∈ ℕ exige:", opcoes: [{ label: "A", valor: "Testar apenas um valor" }, { label: "B", valor: "Testar se 2x < 14 → x < 7 e conferir os limítrofes como x=6 e x=7" }, { label: "C", valor: "Jogar o 0" }, { label: "D", valor: "Resolver por Bhaskara" }, { label: "E", valor: "Tirar a raiz do erro" }], correta: "B", explicacao: "Na desigualdade o mais seguro é olhar o limite. Se x<7, jogue o 6: 12-4 = 8 < 10 (Funciona). Jogue o 7: 14-4 = 10 < 10 (FALSO). Comprova a zona limite da resposta." },
  { id: 705, pergunta: "Por que testar as soluções de um sistema 3x3 nas 3 equações e não apenas em uma?", opcoes: [{ label: "A", valor: "Pode ser que existam múltiplas respostas certas." }, { label: "B", valor: "O gabarito testa na primeira, mas fura propositalmente na última." }, { label: "C", valor: "Pra perder tempo." }, { label: "D", valor: "Ele engana na soma e não na subtração." }, { label: "E", valor: "Sistemas mentem com facilidade." }], correta: "B", explicacao: "Bancas malandras colocam nas alternativas pares ordenados que funcionam perfeitamente na 1ª e na 2ª equação, para pegar o apressado, mas furam na 3ª. Deve-se testar nas três." },
  { id: 706, pergunta: "Para x = 8 ser validado na equação (x/2) + 3 = 7, faríamos:", opcoes: [{ label: "A", valor: "Apenas (x/2) = 4" }, { label: "B", valor: "(8/2) + 3 = 4 + 3 = 7 ✓. A balança ficou perfeitamente equilibrada." }, { label: "C", valor: "Testar x = -8 pra confirmar" }, { label: "D", valor: "Substituir 8 no lugar de 7" }, { label: "E", valor: "Isolar a balança no final" }], correta: "B", explicacao: "Prova real significa apagar temporalmente a certeza e só checar se os dois lados resultam no exato mesmo peso no mesmo instante. 7 = 7." },
];

// ═══ MÓDULO 8 — PEGADINHAS ═══
export const QUIZ_M8_PEGADINHAS: QuizQuestion[] = [
  { id: 801, pergunta: "Qual o erro comum ao resolver -x > 5?", opcoes: [{ label: "A", valor: "Esquecer de somar 5" }, { label: "B", valor: "Não inverter o sinal da desigualdade" }, { label: "C", valor: "Mudar o valor numérico" }, { label: "D", valor: "Dividir por 2" }, { label: "E", valor: "Trocar x por y" }], correta: "B", explicacao: "Ao multiplicar ou dividir por -1, o sinal de '>' deve obrigatoriamente inverter para '<'. Resultado: x < -5." },
  { id: 802, pergunta: "Na equação -3x = 15, o erro fatal é pensar que:", opcoes: [{ label: "A", valor: "O x é negativo." }, { label: "B", valor: "O -3 vai para o outro lado somando (+3) em vez de dividindo negativo." }, { label: "C", valor: "15 não divide por 3" }, { label: "D", valor: "A equação não tem raízes" }, { label: "E", valor: "O módulo é necessário" }], correta: "B", explicacao: "A operação que inverte é a multiplicação! O 'vezes' inverte pra 'divisão'. O número (-3) vai inteiro! x = 15 / (-3) = -5. Trocar a multiplicação pra adição quebra a igualdade." },
  { id: 803, pergunta: "Ao deparar-se com 'O salário AUMENTOU em R$ 300, ficando 20% maior', o raciocínio S+300=S+0,20 está:", opcoes: [{ label: "A", valor: "Certo." }, { label: "B", valor: "Errado, porque deveria ser multiplicativo." }, { label: "C", valor: "Errado, porque R$ 300 é EXATAMENTE esses 20%." }, { label: "D", valor: "Incompleto para as frações" }, { label: "E", valor: "Irresolvível." }], correta: "C", explicacao: "O erro mortal: 'Aumento nominal' x 'Aumento percentual'. Se ele aumentou R$ 300 e esse aumento representou 20%, o correto é 0,20 * S = 300. Se falar 'ficou 20% maior', S+300 = S*1,20." },
  { id: 804, pergunta: "Como se traduz matematicamente 'Um número somado a sua metade'?", opcoes: [{ label: "A", valor: "x + y" }, { label: "B", valor: "x/2" }, { label: "C", valor: "x + x/2" }, { label: "D", valor: "2x" }, { label: "E", valor: "½ + x" }], correta: "C", explicacao: "Se o número é x, a metade DELE é x/2. Muito comum candidato escrever `x + 1/2`." },
  { id: 805, pergunta: "Isolando 'M' de F = M*A. Se M for o foco, A passa:", opcoes: [{ label: "A", valor: "Subtraindo" }, { label: "B", valor: "Dividindo para baixo do F." }, { label: "C", valor: "Somando." }, { label: "D", valor: "Multiplicando." }, { label: "E", valor: "Elevando a potência." }], correta: "B", explicacao: "M = F / A. Parece inocente, mas errar a 'passada para o outro lado' de fórmulas da Física/Química em Álgebra pura elimina quem não treinou isolar variáveis." },
  { id: 806, pergunta: "Resolvendo 2-(x-1) = 5. O erro de sinal estaria na linha:", opcoes: [{ label: "A", valor: "2-x-1 = 5" }, { label: "B", valor: "2-x+1 = 5" }, { label: "C", valor: "x = -2" }, { label: "D", valor: "-x = 2" }, { label: "E", valor: "-x+3 = 5" }], correta: "A", explicacao: "O negativo na frente dos parênteses DISTRIBUI para TUDO o que está dentro! O certo é: 2 - x - (-1) → 2 - x + 1. Quem faz 2-x-1 perdeu a batalha." },
];

// ═══ MÓDULO 9 — PETROBRAS ESPECÍFICO ═══
export const QUIZ_M9_PETROBRASESPECIFICO: QuizQuestion[] = [
  { id: 901, pergunta: "Um problema Petrobras de 'mistura de óleos' geralmente resulta em:", opcoes: [{ label: "A", valor: "Uma equação de 2º grau" }, { label: "B", valor: "Um sistema de equações de 1º grau" }, { label: "C", valor: "Um logaritmo" }, { label: "D", valor: "Uma matriz 4x4" }, { label: "E", valor: "Uma integral" }], correta: "B", explicacao: "Problemas de misturas, onde você tem quantidades e concentrações diferentes, caem invariavelmente em sistemas lineares de 1º grau." },
  { id: 902, pergunta: "Uma bomba Y enche um tanque do refino em 'x' horas. A bomba W é o dobro mais rápida. Juntas elas enchem em 4h. Qual equação modela isso?", opcoes: [{ label: "A", valor: "x + 2x = 4" }, { label: "B", valor: "1/x + 1/(x/2) = 1/4" }, { label: "C", valor: "4(x) + 4(2x) = 1" }, { label: "D", valor: "x/2 = 4" }, { label: "E", valor: "(1/x)*2 = 4" }], correta: "B", explicacao: "Problema de vazão/trabalho conjunto: (1/T_A) + (1/T_B) = 1/T_total. Se W é o dobro mais rápida, seu tempo é a metade (x/2). Então: 1/x + 2/x = 1/4." },
  { id: 903, pergunta: "Um cabo de aço perdeu 1/3 do seu tamanho sob fadiga, e depois cortaram mais 5m dessa sobra da inspeção, restando 15m. O tamanho original era:", opcoes: [{ label: "A", valor: "20m" }, { label: "B", valor: "24m" }, { label: "C", valor: "25m" }, { label: "D", valor: "30m" }, { label: "E", valor: "35m" }], correta: "D", explicacao: "(2/3)*x - 5 = 15 → (2/3)x = 20 → 2x = 60 → x = 30 metros." },
  { id: 904, pergunta: "Para produzir 1 barril de nafta, usa-se 3h no equipamento A e 2h no B. O limite mensal de horas no equipamento B é de 400h. Se fizermos x barris, a inequação é:", opcoes: [{ label: "A", valor: "3x + 2x ≤ 400" }, { label: "B", valor: "x ≤ 400" }, { label: "C", valor: "2x ≤ 400" }, { label: "D", valor: "3x ≤ 400" }, { label: "E", valor: "x/2 ≤ 400" }], correta: "C", explicacao: "Cada barril exige 2h do eq B. Logo o gasto total nele é 2x. Restrição: 2x ≤ 400. Ou seja, produção máx é 200 barris." },
  { id: 905, pergunta: "Em um navio-petroleiro a soma dos 4 contêineres P1, P2, P3 e P4 em fila excede a capacidade de 40. P2 pesa 2 a mais que P1. P3 pesa 2 a mais que P2. P4 = P3+2. Todos têm pesos inteiros consecutivos. Qual a equação?", opcoes: [{ label: "A", valor: "P1 + (P1+2) + (P1+4) + (P1+6) = 40" }, { label: "B", valor: "4P1 = 40" }, { label: "C", valor: "P1 + 2 = 40" }, { label: "D", valor: "P1*P2*P3*P4 = 40" }, { label: "E", valor: "40 - 2x = P1" }], correta: "A", explicacao: "Uma PA algébrica onde x, (x+razão) são somados. Essencial para transformar 'progressões' em equações de primeiro grau. Tradução exata de progressão aritmética em variável única!" },
  { id: 906, pergunta: "A multa para navios varia fixamente com +10.000R$ a cada Km derramado. Custo fixo da autuação: 200 mil. Se a multa foi 600 mil, qual equação usar e quanto derramou?", opcoes: [{ label: "A", valor: "200.000 + 10.000*k = 600.000 / k=40" }, { label: "B", valor: "10.000*k = 600.000 / k=60" }, { label: "C", valor: "200.000 + 10.000 = k / 21" }, { label: "D", valor: "210.000*k = 600.000" }, { label: "E", valor: "(200 + 10)*k = 600" }], correta: "A", explicacao: "Modelagem clássica de 'Função Afim': y = b + a(x). Taxa fixa (b=200k) + Taxa Variável(10k * k). 10.000*k = 400.000 → k = 40 km de mancha." },
];

// ═══ MÓDULO 10 — SIMULADO MESTRE ═══
export const QUIZ_M10_SIMULADO_MESTRE: QuizQuestion[] = [
  { id: 1001, pergunta: "Se 3x + 2y = 12 e x - y = 4, o valor de x é:", opcoes: [{ label: "A", valor: "2" }, { label: "B", valor: "3" }, { label: "C", valor: "4" }, { label: "D", valor: "5" }, { label: "E", valor: "0" }], correta: "C", explicacao: "Da segunda: y = x - 4. Na primeira: 3x + 2(x-4) = 12 → 5x = 20 → x = 4. Logo, y = 0. Verificação: 4-0=4 ✓." },
  { id: 1002, pergunta: "Qual a solução para (2x-1)/3 - (x+2)/4 = 1?", opcoes: [{ label: "A", valor: "2" }, { label: "B", valor: "4.4" }, { label: "C", valor: "5" }, { label: "D", valor: "22/5" }, { label: "E", valor: "14/5" }], correta: "D", explicacao: "MMC(3,4) = 12. Multiplicando tudo por 12: 4(2x-1) - 3(x+2) = 12. Distributiva: 8x-4 - 3x-6 = 12. 5x - 10 = 12 → 5x = 22 → x = 22/5 = 4,4." },
  { id: 1003, pergunta: "A Cia Alfa paga salário-base R$1500 + 20/h extra. Cia Beta: R$1000 + 30/h extra. Em que ponto se equilibram?", opcoes: [{ label: "A", valor: "25 h" }, { label: "B", valor: "30 h" }, { label: "C", valor: "40 h" }, { label: "D", valor: "50 h" }, { label: "E", valor: "60 h" }], correta: "D", explicacao: "Equilíbrio: y1 = y2 → 1500 + 20x = 1000 + 30x → 500 = 10x → x = 50 horas de trabalho." },
  { id: 1004, pergunta: "O dobro do antecedente de um número menos o triplo de seu sucessor resulta -13. Qual é o número?", opcoes: [{ label: "A", valor: "6" }, { label: "B", valor: "7" }, { label: "C", valor: "8" }, { label: "D", valor: "9" }, { label: "E", valor: "10" }], correta: "C", explicacao: "Antecedente: (x-1). Sucessor: (x+1). 2(x-1) - 3(x+1) = -13. 2x - 2 - 3x - 3 = -13. -x - 5 = -13. -x = -8 → x=8." },
  { id: 1005, pergunta: "Qual é o menor inteiro 'k' para que k - (2k-3)/5 > 2?", opcoes: [{ label: "A", valor: "1" }, { label: "B", valor: "2" }, { label: "C", valor: "3" }, { label: "D", valor: "4" }, { label: "E", valor: "0" }], correta: "C", explicacao: "Multiplicando por 5 (como é > 0 o sinal mantém): 5k - (2k-3) > 10. 5k - 2k + 3 > 10 → 3k > 7 → k > 2,33. Menor inteiro é 3." },
  { id: 1006, pergunta: "Sistema de equação: x + y = 35 e x/y = 4/3. A diferença (x-y) vale:", opcoes: [{ label: "A", valor: "5" }, { label: "B", valor: "10" }, { label: "C", valor: "15" }, { label: "D", valor: "20" }, { label: "E", valor: "25" }], correta: "A", explicacao: "Isolando x na 2ª: x = (4y)/3. Substituindo: 4y/3 + y = 35 → 7y/3 = 35 → y = 15. x = 20. X-Y = 20-15 = 5." },
  { id: 1007, pergunta: "CESGRANRIO: Do salário bruto de Luís, há um corte de 11% (INSS), depois 15% do que sobrou vai para Plano de Saúde (R$ 400,50). O salário Bruto dele é:", opcoes: [{ label: "A", valor: "3000" }, { label: "B", valor: "3500" }, { label: "C", valor: "2800" }, { label: "D", valor: "2900" }, { label: "E", valor: "4000" }], correta: "A", explicacao: "0,15 * Sobra = 400,50 → Sobra = 2.670 (que é o que sobra após os 11% do INSS, logo é 89%). 0,89 * S = 2670 → S = 2670 / 0,89 = R$ 3.000." },
  { id: 1008, pergunta: "Para 'ax + b > 0' ter como resposta x < c, é obrigatório focar que 'a' é:", opcoes: [{ label: "A", valor: "Zero" }, { label: "B", valor: "Positivo" }, { label: "C", valor: "Negativo" }, { label: "D", valor: "Fraço" }, { label: "E", valor: "Irracional" }], correta: "C", explicacao: "O único jeito do sinal de MAIOR virar MENOR no final é quando você divide tudo por um número que era negativo. Essa regra elimina candidatos!" },
];
```

